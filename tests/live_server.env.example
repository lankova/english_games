# Copy to live_server.env (or export in your shell) before running live tests.
# Windows PowerShell:
#   Get-Content tests\live_server.env | ForEach-Object {
#     if ($_ -match '^\s*([^#][^=]+)=(.*)$') { Set-Item -Path "env:$($matches[1])" -Value $matches[2] }
#   }

LIVE_TESTS_OK=1
# Site URL (usually leave as-is when you only move files to a new server)
LIVE_GAME_SERVER_URL=https://lankova.tech
LIVE_LOAD_ROOMS=10
LIVE_LOAD_PLAYERS=15
LIVE_EVENT_TIMEOUT=20
LIVE_SPY_EVENT_TIMEOUT=60
LIVE_LOAD_PARALLEL=5
LIVE_SPY_LOAD_PARALLEL=2
LIVE_SPY_ROLE_READY_PAUSE=0.1
LIVE_SSL_VERIFY=1
LIVE_TRANSPORTS=polling
