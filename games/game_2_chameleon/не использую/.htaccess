#преобразуем URL при выборе игры
<IfModule mod_rewrite.c>
     RewriteEngine on
     RewriteBase /
     RewriteCond %{HTTP_HOST} ^https://english-games.ru/blendin.html
     RewriteRule (.*) https://english-games.ru/blendin.html/$1 [R=301,L]
     RewriteCond %{THE_REQUEST} ^[A-Z] {3,9}\ /index\.html\ HTTP/
     RewriteRule ^index\.html$ https://english-games.ru/blendin.html/ [R=301,L]
</IfModule>

ServerSignature Off
AddDefaultCharset Utf-8

RewriteRule ^123?$[NC}